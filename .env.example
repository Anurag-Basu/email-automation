# Copy to .env.local for local development

# Optional: store leads outside the repo (absolute path). Reduces dev file churn under the project folder.
# LEADS_DATA_DIR=/tmp/email-automation-data

# --- SMTP (Gmail: use an App Password, not your normal password) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=you@gmail.com
EMAIL_FROM_NAME=Your name

# Shown in the email body ("Best regards," line)
EMAIL_SIGNATURE_NAME=Your name

# Optional overrides (defaults match product spec). Placeholders: {{name}}, {{role}}, {{signature}}
# EMAIL_SUBJECT_TEMPLATE=Opportunity for {{role}} role
# EMAIL_BODY_TEMPLATE=Hi {{name}},\n\nI came across your profile regarding {{role}} opportunities.\n\nPlease find my resume attached.\n\nBest regards,\n{{signature}}

# Set to true to log sends without contacting SMTP (good for UI / flow tests)
SMTP_DRY_RUN=false
