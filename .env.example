# Copy to `.env` (Docker Compose `env_file` + bind mount) or `.env.local` for `npm run dev`.
#
# TODO(before production deploy): Do not mount or commit `.env` in production Docker — use
# secrets / platform env instead. See `docker-compose.yml` and `Dockerfile` comments.

# Optional: store leads outside the repo (absolute path). Reduces dev file churn under the project folder.
# LEADS_DATA_DIR=/tmp/email-automation-data

# --- SMTP (Gmail: use an App Password, not your normal password) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=you@gmail.com
EMAIL_FROM_NAME=Your name

# Shown in the email body ("Best regards," line)
EMAIL_SIGNATURE_NAME=Your name

# Optional overrides (defaults match product spec). Placeholders: {{name}}, {{role}}, {{signature}}
# EMAIL_SUBJECT_TEMPLATE=Opportunity for {{role}} role
# EMAIL_BODY_TEMPLATE=Hi {{name}},\n\nI came across your profile regarding {{role}} opportunities.\n\nPlease find my resume attached.\n\nBest regards,\n{{signature}}

# When true, NO real email is sent (Gmail is never contacted). You only get a fake
# message id — use false + real SMTP_* / EMAIL_FROM for real delivery.
SMTP_DRY_RUN=false

# Set to true to disable POST /api/test-email and /test (e.g. public deploy)
# DISABLE_EMAIL_TEST=true

# --- Vertex / Gemini Enterprise ---
# Project + region (required for Vertex in this app)
# GOOGLE_CLOUD_PROJECT=project-40bf9d6a-3b6c-4ff3-870
# Gemini Enterprise (this app uses enterprise: true): use location "global" unless Google docs say otherwise for your org.
# GOOGLE_CLOUD_LOCATION=global
# Service account: email-automation@project-40bf9d6a-3b6c-4ff3-870.iam.gserviceaccount.com
# Docker Compose: put any `*.json` key under ./secrets/ (gitignored), mount path /run/gcp/, then e.g.:
# GOOGLE_APPLICATION_CREDENTIALS=/run/gcp/project-40bf9d6a-3b6c-4ff3-870-your-key-id.json
# Local npm run dev (no Docker): use host absolute path to the same JSON file instead.
# Optional model (Agent Platform catalog; default in code is gemini-2.5-flash). If you see 404 NOT_FOUND, try this or check Cloud docs for your project.
# VERTEX_GEMINI_MODEL=gemini-2.5-flash
# Optional: posts per Vertex request when classifying CSV imports (1–80, default 25)
# CLASSIFY_VERTEX_BATCH_SIZE=25
# Set to true to disable GET/POST /api/test-vertex
# DISABLE_VERTEX_TEST=true

# When true, `/api/test-vertex` JSON includes a `debug` object (timings, char counts, error
# previews). Use in Docker without reading container logs: inspect Network → Response.
# Turn off in production. Docker: set in `.env` (see compose `env_file`) or `environment:`.
# DEBUG_TEST_VERTEX=true
